@model InvoiceSaaS.Application.DTOs.Dashboard.SuperAdminStatsDto
@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";
    ViewBag.ActiveMenu = "dashboard";
    string Fmt(decimal v) => v >= 1_000_000
        ? (v / 1_000_000m).ToString("N1") + "M"
        : v >= 1_000 ? (v / 1_000m).ToString("N1") + "K"
        : v.ToString("N0");
}

@* SuperAdmin blocked-page redirect banner *@
@if (Context.Request.Query.ContainsKey("sa_blocked"))
{
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-4 border-0"
         style="background:#FFFBEB;border-left:4px solid #F59E0B!important;border-radius:8px;">
        <i class="bi bi-exclamation-triangle-fill text-warning"></i>
        <div>
            <strong>Access restricted.</strong>
            As SuperAdmin you cannot access company data directly.
            Use the <a href="/SuperAdmin/Company" class="fw-600">Companies</a> page to manage company accounts.
        </div>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-1 fw-bold">Platform Dashboard</h4>
        <p class="text-muted mb-0" style="font-size:.83rem;">
            Welcome, <strong>@ViewBag.CurrentUserName</strong>
            &nbsp;·&nbsp; @DateTime.Now.ToString("dddd, dd MMM yyyy")
        </p>
    </div>
    <a href="/SuperAdmin/Company" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Company
    </a>
</div>

<!-- ── Platform stat cards ────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div>
                    <div class="stat-label">Total Companies</div>
                    <div class="stat-value mt-1">@Model.TotalCompanies</div>
                </div>
                <div class="stat-icon" style="background:#EEF2FF;color:#4F46E5;">
                    <i class="bi bi-buildings"></i>
                </div>
            </div>
            <div style="font-size:.75rem;color:var(--text-muted);">
                <span class="text-success fw-600">@Model.ActiveCompanies active</span>
                &nbsp;·&nbsp;
                @(Model.TotalCompanies - Model.ActiveCompanies) inactive
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div>
                    <div class="stat-label">Total Users</div>
                    <div class="stat-value mt-1">@Model.TotalUsers</div>
                </div>
                <div class="stat-icon" style="background:#ECFDF5;color:#059669;">
                    <i class="bi bi-people"></i>
                </div>
            </div>
            <div style="font-size:.75rem;color:var(--text-muted);">Across all companies</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div>
                    <div class="stat-label">Total Invoices</div>
                    <div class="stat-value mt-1">@Model.TotalInvoices</div>
                </div>
                <div class="stat-icon" style="background:#FFF7ED;color:#EA580C;">
                    <i class="bi bi-file-earmark-text"></i>
                </div>
            </div>
            <div style="font-size:.75rem;color:var(--text-muted);">Platform-wide</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div>
                    <div class="stat-label">Total Revenue</div>
                    <div class="stat-value mt-1">@Fmt(Model.TotalRevenue)</div>
                </div>
                <div class="stat-icon" style="background:#F0FDF4;color:#16A34A;">
                    <i class="bi bi-currency-exchange"></i>
                </div>
            </div>
            <div style="font-size:.75rem;color:var(--text-muted);">All paid invoices</div>
        </div>
    </div>
</div>

<!-- ── Recent companies table ─────────────────────────────── -->
<div class="row g-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span class="card-title">Recent Companies</span>
                <a href="/SuperAdmin/Company" class="btn btn-sm btn-outline-primary">
                    View All
                </a>
            </div>
            @if (Model.RecentCompanies.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Company</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.RecentCompanies)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div style="width:34px;height:34px;border-radius:8px;
                                                background:linear-gradient(135deg,#4F46E5,#7C3AED);
                                                display:flex;align-items:center;justify-content:center;
                                                color:#fff;font-weight:700;font-size:.85rem;flex-shrink:0;">
                                                @c.Name[0].ToString().ToUpper()
                                            </div>
                                            <span class="fw-600 fs-13">@c.Name</span>
                                        </div>
                                    </td>
                                    <td class="text-muted fs-13">@(c.Email ?? "—")</td>
                                    <td>
                                        @if (c.IsActive)
                                        {
                                            <span class="badge" style="background:#ECFDF5;color:#065F46;font-size:.7rem;">
                                                <i class="bi bi-check-circle me-1"></i>Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge" style="background:#FEF2F2;color:#991B1B;font-size:.7rem;">
                                                <i class="bi bi-x-circle me-1"></i>Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="text-muted fs-13">@c.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td class="text-end">
                                        <a href="/SuperAdmin/Company" class="btn btn-icon btn-outline-primary border-0"
                                               data-bs-toggle="tooltip" title="Manage">
                                            <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state py-5 text-center">
                    <div class="empty-state-icon"><i class="bi bi-buildings"></i></div>
                    <h6>No companies yet</h6>
                    <p class="text-muted fs-13">Create the first company to get started.</p>
                    <a href="/SuperAdmin/Company" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-lg me-1"></i>Create Company
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var tooltipEls = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipEls.map(function(el){ return new bootstrap.Tooltip(el); });
    </script>
}
