@model IEnumerable<ProductDto>
@{
    var perms = ViewBag.Permissions as HashSet<string> ?? new HashSet<string>();
    bool isSA = (bool)(ViewBag.IsSuperAdmin ?? false);
    bool Can(string c) => isSA || perms.Contains(c);
    ViewData["Title"] = "Products";
    ViewBag.ActiveMenu = "products";
    int currentPage = (int)(ViewBag.Page ?? 1);
    int pageSize = (int)(ViewBag.PageSize ?? 20);
    int totalCount = (int)(ViewBag.TotalCount ?? 0);
    int totalPages = (int)(ViewBag.TotalPages ?? 1);
    var activeSearch = ViewBag.Search ?? "";
}

@section Styles {
<style>
.product-type-badge { padding:3px 10px;border-radius:20px;font-size:.72rem;font-weight:600; }
.type-service  { background:#EFF6FF;color:#2563EB; }
.type-physical { background:#F0FDF4;color:#15803D; }
</style>
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-1">Products</h4>
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active">Products</li>
        </ol></nav>
    </div>
    @if(Can("products.create")){
    <button class="btn btn-primary" onclick="openModal()">
        <i class="bi bi-plus-lg me-1"></i> Add Product
    </button>
    }
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-3">
        <div class="input-group input-group-sm" style="max-width:340px">
            <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" id="searchInput" class="form-control border-start-0" placeholder="Search name or SKU…" value="@activeSearch" oninput="filterTable()">
        </div>
        <div class="d-flex align-items-center justify-content-end mt-2">
            <div class="text-muted small me-3">@Model.Count() products</div>
        </div>
    </div>
</div>

<div id="productsListCard" class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle" id="productsTable">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>SKU</th>
                        <th>Type</th>
                        <th class="text-end">Sale Price</th>
                        <th class="text-end">Cost Price</th>
                        <th class="text-end">Tax %</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="tbody">
                @foreach(var p in Model){
                    <tr>
                        <td>
                            <div class="fw-600">@p.Name</div>
                            @if(!string.IsNullOrEmpty(p.Description)){
                            <div class="text-muted small">@(p.Description!.Length > 60 ? p.Description[..60] + "…" : p.Description)</div>
                            }
                        </td>
                        <td class="text-muted small">@(p.SKU ?? "—")</td>
                        <td>
                            <span class="product-type-badge @(p.Type == 0 ? "type-service" : "type-physical")">
                                @p.TypeName
                            </span>
                        </td>
                        <td class="text-end fw-600">@p.SalePrice.ToString("N2")</td>
                        <td class="text-end text-muted">@p.CostPrice.ToString("N2")</td>
                        <td class="text-end text-muted">@p.TaxRate%</td>
                        <td>
                            @if(p.IsActive){
                                <span class="badge bg-success-subtle text-success">Active</span>
                            } else {
                                <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            @if(Can("products.edit")){
                            <button class="btn btn-sm btn-outline-primary me-1" onclick="editProduct('@p.Id')">
                                <i class="bi bi-pencil"></i>
                            </button>
                            }
                            @if(Can("products.delete")){
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteProduct('@p.Id','@p.Name')">
                                <i class="bi bi-trash"></i>
                            </button>
                            }
                        </td>
                    </tr>
                }
                @if(!Model.Any()){
                <tr><td colspan="8" class="text-center text-muted py-5">
                    <i class="bi bi-box-seam fs-2 d-block mb-2 opacity-25"></i>
                    No products yet. Add your first product.
                </td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    @* Pagination *@
    @if (totalPages > 0)
    {
        <div class="card-footer bg-transparent border-top d-flex align-items-center justify-content-between px-3 py-2">
            <span class="text-muted small">
                Showing @((currentPage - 1) * pageSize + 1)–@(Math.Min(currentPage * pageSize, totalCount)) of @totalCount products
            </span>
            <nav>
                <ul class="pagination pagination-sm mb-0 gap-1">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link rounded" href="@BuildUrl(currentPage - 1, activeSearch, pageSize)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @{
                        int start = Math.Max(1, currentPage - 2);
                        int end   = Math.Min(totalPages, start + 4);
                        start     = Math.Max(1, end - 4);
                    }
                    @if (start > 1)
                    {
                        <li class="page-item">
                            <a class="page-link rounded" href="@BuildUrl(1, activeSearch, pageSize)">1</a>
                        </li>
                        @if (start > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }

@functions {
    string BuildUrl(int page, string search, int pageSize)
    {
        var q = new System.Collections.Generic.List<string>();
        if (!string.IsNullOrEmpty(search)) q.Add($"search={Uri.EscapeDataString(search)}");
        q.Add($"page={page}");
        q.Add($"pageSize={pageSize}");
        return "/Product?" + string.Join("&", q);
    }
}
                    @for (int pg = start; pg <= end; pg++)
                    {
                        <li class="page-item @(pg == currentPage ? "active" : "")">
                            <a class="page-link rounded" href="@BuildUrl(pg, activeSearch, pageSize)">@pg</a>
                        </li>
                    }
                    @if (end < totalPages)
                    {
                        @if (end < totalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link rounded" href="@BuildUrl(totalPages, activeSearch, pageSize)">@totalPages</a>
                        </li>
                    }
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link rounded" href="@BuildUrl(currentPage + 1, activeSearch, pageSize)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted small">Per page:</span>
                <select class="form-select form-select-sm" style="width:70px" id="pageSizeSelect">
                    @foreach (var ps in new[] { 10, 20, 50, 100 })
                    {
                        if (ps == pageSize)
                        {
                            <option value="@ps" selected="selected">@ps</option>
                        }
                        else
                        {
                            <option value="@ps">@ps</option>
                        }
                    }
                </select>
            </div>
        </div>
    }
</div>

<!-- Save Modal -->
<div class="modal fade" id="productModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="pId">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label">Product Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="pName" placeholder="e.g. Web Design Service">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">SKU / Code</label>
                        <input type="text" class="form-control" id="pSku" placeholder="e.g. WDS-001">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Type</label>
                        <select class="form-select" id="pType">
                            <option value="0">Service</option>
                            <option value="1">Physical</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Sale Price <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">₹</span>
                            <input type="number" class="form-control" id="pSalePrice" min="0" step="0.01" value="0">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Cost Price</label>
                        <div class="input-group">
                            <span class="input-group-text">₹</span>
                            <input type="number" class="form-control" id="pCostPrice" min="0" step="0.01" value="0">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Tax Rate %</label>
                        <input type="number" class="form-control" id="pTaxRate" min="0" max="100" step="0.01" value="0">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Unit</label>
                        <input type="text" class="form-control" id="pUnit" placeholder="hrs, pcs, kg…">
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="pIsActive" checked>
                            <label class="form-check-label" for="pIsActive">Active</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" id="pDesc" rows="2" placeholder="Optional description…"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSave" onclick="saveProduct()">
                    <i class="bi bi-check-lg me-1"></i> Save Product
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var modal = new bootstrap.Modal(document.getElementById('productModal'));

function openModal(){ clearForm(); document.getElementById('modalTitle').textContent='Add Product'; modal.show(); }

function clearForm(){
    ['pId','pName','pSku','pUnit','pDesc'].forEach(id=>document.getElementById(id).value='');
    document.getElementById('pType').value='0';
    document.getElementById('pSalePrice').value='0';
    document.getElementById('pCostPrice').value='0';
    document.getElementById('pTaxRate').value='0';
    document.getElementById('pIsActive').checked=true;
}

function editProduct(id){
    $.get('/Product/Get?id='+id, function(res){
        if(!res.success){ toastError(res.message); return; }
        var d=res.data;
        document.getElementById('pId').value=d.id;
        document.getElementById('pName').value=d.name;
        document.getElementById('pSku').value=d.sku||'';
        document.getElementById('pType').value=d.type;
        document.getElementById('pSalePrice').value=d.salePrice;
        document.getElementById('pCostPrice').value=d.costPrice;
        document.getElementById('pTaxRate').value=d.taxRate;
        document.getElementById('pUnit').value=d.unit||'';
        document.getElementById('pIsActive').checked=d.isActive;
        document.getElementById('pDesc').value=d.description||'';
        document.getElementById('modalTitle').textContent='Edit Product';
        modal.show();
    });
}

function saveProduct(){
    var name=document.getElementById('pName').value.trim();
    var salePrice = parseFloat(document.getElementById('pSalePrice').value);

    if(!name){ toastError('Product name is required.'); return; }
    if(!(salePrice) || salePrice <= 0){ toastError('Sale Price is required.');return;}

    var $btn=$('#btnSave').prop('disabled',true).html('<span class="spinner-border spinner-border-sm"></span>');
    var dto={
        id: document.getElementById('pId').value||null,
        name: name,
        sku: document.getElementById('pSku').value.trim()||null,
        type: parseInt(document.getElementById('pType').value),
        //salePrice: parseFloat(document.getElementById('pSalePrice').value)||0,
        salePrice:salePrice,
        costPrice: parseFloat(document.getElementById('pCostPrice').value)||0,
        taxRate: parseFloat(document.getElementById('pTaxRate').value)||0,
        unit: document.getElementById('pUnit').value.trim()||null,
        isActive: document.getElementById('pIsActive').checked,
        description: document.getElementById('pDesc').value.trim()||null
    };
    ajaxPost('/Product/Save', dto, $btn).done(function(res){
        $btn.prop('disabled',false).html('<i class="bi bi-check-lg me-1"></i> Save Product');
        if(res.success){ toastSuccess(res.message); modal.hide(); setTimeout(()=>location.reload(),700); }
        else toastError(res.message);
    });
}

function deleteProduct(id,name){
    confirmDelete({ title:'Delete product?', text:'"'+name+'"' }).then(function(r){
        if(!r.isConfirmed) return;
        ajaxPost('/Product/Delete?id='+id,{}).done(function(res){
            if(res.success){ toastSuccess(res.message); setTimeout(()=>location.reload(),700); }
            else toastError(res.message);
        });
    });
}

function filterTable(){
    var q=document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('#tbody tr').forEach(function(tr){
        tr.style.display=tr.textContent.toLowerCase().includes(q)?'':'none';
    });
}
// AJAX helpers to load product list without full page reload
function loadProductsFromUrl(url) {
    $.get(url).done(function(html){
        var tmp = $('<div>').append($.parseHTML(html));
        var newCard = tmp.find('#productsListCard');
        if (newCard.length) {
            $('#productsListCard').replaceWith(newCard);
            setupPaginationHandlers();
        } else {
            // fallback: full navigaton
            window.location.href = url;
        }
    }).fail(function(){ toastError('Failed to load products.'); });
}

function setupPaginationHandlers() {
    // page-size selector — load first page with new size
    $('#pageSizeSelect').off('change').on('change', function(){
        var ps = $(this).val();
        var s = encodeURIComponent($('#searchInput').val()||'');
        var url = '/Product?page=1&pageSize=' + ps + (s ? '&search=' + s : '');
        loadProductsFromUrl(url);
    });

    // pagination links — load via AJAX
    $(document).off('click', '#productsListCard .pagination a').on('click', '#productsListCard .pagination a', function(e){
        e.preventDefault();
        var href = $(this).attr('href');
        if (href) loadProductsFromUrl(href);
    });
}

// initialize handlers
setupPaginationHandlers();
</script>
}
