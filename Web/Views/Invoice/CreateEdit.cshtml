// ════════════════════════════════════════════════════════════
//  SAVE INVOICE
// ════════════════════════════════════════════════════════════
function saveInvoice(sendNow) {
    // Validate
    const clientId  = $('#clientId').val();
    const issueDate = $('#issueDate').val();
    const dueDate   = $('#dueDate').val();
    

    // At the very top of saveInvoice(), before existing validation:
const requiresRemark = @(((bool)(ViewBag.RequiresRemark ?? false)) ? "true" : "false");

// After the dueDate validation check, add:
if (requiresRemark) {
    const remark = $('#editRemark').val().trim();
    if (!remark) {
        toastError('A remark is required when editing a sent invoice.');
        $('#editRemark').focus();
        return;
    }
}





    if (!clientId)  { toastError('Please select a client.'); $('#clientId').focus(); return; }
    if (!issueDate) { toastError('Issue date is required.'); return; }
    if (!dueDate)   { toastError('Due date is required.'); return; }
    if (dueDate < issueDate) { toastError('Due date must be on or after the issue date.'); return; }
//     function parseDate(str) { const [d, m, y] = str.split('/');
//     return new Date(y, m - 1, d);
//     }

//     if (parseDate(dueDate) < parseDate(issueDate)) { toastError('Due date must be on or after the issue date.');
//     return;
// }
//     if (!items.length) {
//         Swal.fire({ icon:'warning', title:'No Items', text:'Add at least one line item.', confirmButtonColor:'#2563EB' });
//         return;
//     }



    // ── Items required ────────────────────────────────────────
if (!items.length) {
    Swal.fire({
        icon: 'warning',
        title: 'No Items',
        text: 'Add at least one line item.',
        confirmButtonColor: '#2563EB'
    });
    return;
}

    const emptyDesc = items.some(i => !i.description.trim());
    if (emptyDesc) { toastError('All line items must have a description.'); return; }
    const badQty = items.some(i => +i.quantity <= 0);
    if (badQty) { toastError('All item quantities must be greater than 0.'); return; }

    const payload = {
        isEdit,
        id:        isEdit ? invId : null,
        clientId,
        issueDate,
        dueDate,
        taxRate:   +$('#taxRate').val() || 0,
        discount:  +$('#discount').val() || 0,
        notes:     $('#notes').val().trim(),
        terms:     $('#terms').val().trim(),
        sendNow:   sendNow,
        currencyCode: $('#invoiceCurrency').val() || 'INR',
        exchangeRate: parseFloat($('#exchangeRate').val()) || 1,
        // Inside the payload object, add:
editRemark: requiresRemark ? $('#editRemark').val().trim() : null,

        items:     items.map((it, idx) => ({
            id:          it.id || null,
             productId: it.productId || null,
            description: it.description.trim(),
            quantity:    +it.quantity,
            unitPrice:   +it.unitPrice,
            sortOrder:   idx
        }))
    };

    // Show loading
    if (sendNow) {
        Swal.fire({ title:'Saving & Sending…', didOpen:()=>Swal.showLoading(), allowOutsideClick:false });
    } else {
        const $btn = sendNow ? null : ($('#btnSaveDraft').prop('disabled',true), $('#btnSaveDraft'));
    }

    $.ajax({
        url: '/Invoice/Save',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(payload),
        headers: { 'RequestVerificationToken': getCsrfToken() }
    })
    .done(function (res) {
        Swal.close();
        if (res.success) {
            const msg = sendNow ? 'Invoice saved and sent to client!' : (res.message || 'Invoice saved.');
            Swal.fire({
                icon: 'success', title: sendNow ? 'Sent!' : 'Saved!', text: msg,
                timer: 1500, showConfirmButton: false
            }).then(() => {
                window.location.href = '/Invoice/Detail/' + res.data.id;
            });
        } else {
            showFormErrors(res.errors?.length ? res.errors : [res.message]);
            $('#btnSaveDraft, #btnSaveDraft2').prop('disabled', false);
        }
    })
    .fail(function () {
        Swal.close();
        toastError('Server error. Please try again.');
        $('#btnSaveDraft, #btnSaveDraft2').prop('disabled', false);
    });
}

$('#btnSaveDraft,  #btnSaveDraft2').on('click', () => saveInvoice(false));
$('#btnSaveSend,   #btnSaveSend2').on('click',  () => saveInvoice(true));

// ════════════════════════════════════════════════════════════
//  QUICK ADD CLIENT
// ════════════════════════════════════════════════════════════
const qcModal = new bootstrap.Modal(document.getElementById('quickClientModal'));

function openQuickClient() {
    $('#quickClientBody').html('<div class="text-center p-5"><div class="spinner-border text-primary"></div></div>');
    qcModal.show();
    $.get('/Client/Create').done(html => $('#quickClientBody').html(html))
                           .fail(() => $('#quickClientBody').html('<p class="text-danger p-3">Failed to load.</p>'));
}

// Override saveClient() to refresh dropdown after creation
window._origSaveClient = window.saveClient;
window.saveClient = function () {
    const name = $('#clientName').val().trim();
    if (!name) { toastError('Client name is required.'); return; }
    const data = {
        name, 
        email:$('#clientEmail').val().trim(),
        phone:$('#clientPhone').val().trim(),
        address:$('#address').val().trim(), city:$('#city').val().trim(),
        state:$('#state').val().trim(), country:$('#country').val().trim(),
        postalCode:$('#postalCode').val().trim(), taxNumber:$('#taxNumber').val().trim(),
        notes:$('#notes_client').val()?.trim() || '',
        currencyCode: $('#clientCurrency').val() || 'INR',
        isActive: true
    };
    ajaxPost('/Client/Create', data)
        .done(res => {
            if (res.success) {
                qcModal.hide();
                toastSuccess('Client created!');
                // Add to select and pick it
                const opt = new Option(res.data.name, res.data.id, true, true);
                $('#clientId').append(opt).val(res.data.id);
            } else {
                showFormErrors(res.errors?.length ? res.errors : [res.message]);
            }
        })
        .fail(() => toastError('Server error.'));
};

