@using InvoiceSaaS.Domain.Enums
@{
    bool isEdit   = ViewBag.InvoiceId != null;
    var  invId    = ViewBag.InvoiceId?.ToString() ?? "";
    var  existing = ViewBag.ExistingInvoice as InvoiceSaaS.Application.DTOs.Invoices.InvoiceDto;
    var  clients  = (ViewBag.Clients as IEnumerable<InvoiceSaaS.Application.DTOs.Common.SelectItemDto>)
                    ?? Enumerable.Empty<InvoiceSaaS.Application.DTOs.Common.SelectItemDto>();
    var preselected = ViewBag.PreselectedClientId as string ?? "";

    var products = (ViewBag.Products as IEnumerable<InvoiceSaaS.Application.DTOs.Common.SelectItemDto>)
               ?? Enumerable.Empty<InvoiceSaaS.Application.DTOs.Common.SelectItemDto>();

    bool isSA = (bool)(ViewBag.IsSuperAdmin ?? false);
    var perms = (ViewBag.Permissions as HashSet<string>) ?? new HashSet<string>();
    bool can(string c) => isSA || perms.Contains(c);

    // Seed items for edit mode
    var seedItems = existing?.Items ?? new List<InvoiceSaaS.Application.DTOs.Invoices.InvoiceItemDto>();
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h4 class="mb-1">@(isEdit ? $"Edit {existing?.InvoiceNumber}" : "New Invoice")</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/Invoice">Invoices</a></li>
                <li class="breadcrumb-item active">@(isEdit ? "Edit" : "Create")</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        <a href="/Invoice@(isEdit ? "/Detail/" + invId : "")" class="btn btn-outline-secondary">
            <i class="bi bi-x-lg me-1"></i>Cancel
        </a>
        @if (can("invoices.send"))
        {
            <button class="btn btn-outline-success" id="btnSaveSend">
                <i class="bi bi-send me-1"></i>Save &amp; Send
            </button>
        }
        <button class="btn btn-primary" id="btnSaveDraft">
            <i class="bi bi-check-lg me-1"></i>Save as Draft
        </button>
    </div>
</div>

