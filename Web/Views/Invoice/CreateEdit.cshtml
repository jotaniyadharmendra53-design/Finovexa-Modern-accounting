@section Scripts {

@*     <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    // ── Date Pickers (dd/MM/yyyy) ─────────────────────────────
flatpickr('.date-picker', {
    dateFormat: 'd/m/Y',       // display format
    allowInput: true
}); *@

<script>
    const productsList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    (products ?? []).Select(p => new { value = p.Value, text = p.Text })
));

// ════════════════════════════════════════════════════════════
//  STATE
// ════════════════════════════════════════════════════════════
let items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(seedItems.Select(i => new {
    id          = i.Id?.ToString() ?? "",
     productId   = i.ProductId?.ToString() ?? "", 
    description = i.Description,
    quantity    = i.Quantity,
    unitPrice   = i.UnitPrice
})));
if (!items.length) items = [];

const isEdit  = @(isEdit ? "true" : "false");
const invId   = '@invId';


$(document).on('change', '.item-product', function () {
    const idx = $(this).closest('tr').data('idx');
    const val = $(this).val();

    items[idx].productId = val;

    const prod = productsList.find(p => p.value == val);
    if (!prod) return;

    // extract price (format: "name (100)")
    const match = prod.text.match(/\(([^)]+)\)/);
    const price = match ? parseFloat(match[1]) || 0 : 0;

    items[idx].description = prod.text.split('(')[0].trim();
    items[idx].unitPrice = price;

    const row = $(this).closest('tr');
    row.find('.item-desc').val(items[idx].description);
    row.find('.item-price').val(items[idx].unitPrice);

    const amt = (items[idx].quantity * items[idx].unitPrice).toFixed(2);
    row.find('.item-amount').text(amt);

    calcTotals();
});


// ════════════════════════════════════════════════════════════
//  RENDER ITEMS TABLE
// ════════════════════════════════════════════════════════════
function renderItems() {
    const $body = $('#itemsBody');
    $body.empty();

    if (!items.length) {
        $('#emptyItems').show();
        calcTotals();
        return;
    }
    $('#emptyItems').hide();

    items.forEach((item, idx) => {
        const amt = ((+item.quantity || 0) * (+item.unitPrice || 0)).toFixed(2);
        $body.append(`
        <tr class="invoice-item-row" data-idx="${idx}">
           <td style="padding:.5rem 1rem;">
    <input type="text" class="form-control form-control-sm item-desc"
           value="${escHtml(item.description)}"
           placeholder="Description of service or product"
           maxlength="500"/>

    ${productsList.length ? `
        <select class="form-select form-select-sm mt-1 item-product">
            <option value="">— product —</option>
            ${productsList.map(p => `
                <option value="${p.value}" ${p.value==item.productId?'selected':''}>
                    ${p.text}
                </option>
            `).join('')}
        </select>
    ` : ''}
</td>
            <td style="padding:.5rem .5rem;">
                <input type="number" class="form-control form-control-sm item-qty text-end"
                       value="${item.quantity}" min="0.01" step="0.01" style="min-width:70px;"/>
            </td>
            <td style="padding:.5rem .5rem;">
                <input type="number" class="form-control form-control-sm item-price text-end"
                       value="${item.unitPrice}" min="0" step="0.01" style="min-width:90px;"/>
            </td>
            <td style="padding:.5rem .5rem;">
                <div class="fw-600 text-end item-amount" style="color:var(--primary);padding-right:.25rem;">${amt}</div>
            </td>
            <td style="padding:.5rem .5rem;">
                <button type="button" class="btn btn-icon btn-outline-danger border-0 btn-sm remove-item"
                        data-idx="${idx}" data-bs-toggle="tooltip" title="Remove">
                    <i class="bi bi-trash"></i>
                </button>
            </td>
        </tr>`);
    });

    // Re-init tooltips
    $('[data-bs-toggle="tooltip"]').tooltip('dispose').tooltip();
    calcTotals();
}

// ── Escape HTML ───────────────────────────────────────────────
function escHtml(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

// ════════════════════════════════════════════════════════════
//  TOTALS CALCULATION
// ════════════════════════════════════════════════════════════
function calcTotals() {
    const subTotal = items.reduce((sum, it) => sum + (+it.quantity||0)*(+it.unitPrice||0), 0);
    const taxRate  = +$('#taxRate').val() || 0;
    const discount = +$('#discount').val() || 0;
    const taxAmt   = subTotal * (taxRate / 100);
    const total    = Math.max(0, subTotal + taxAmt - discount);

    $('#displaySubtotal').text(subTotal.toFixed(2));
    $('#displayTax').text(taxAmt.toFixed(2));
    $('#taxPct').text(taxRate.toFixed(2).replace(/\.?0+$/, ''));
    $('#displayDiscount').text('-' + discount.toFixed(2));
    $('#displayTotal').text(total.toFixed(2));
    $('#discountRow').toggle(discount > 0);
    updateConvertedAmount(); 
}

// ════════════════════════════════════════════════════════════
//  EVENT BINDINGS
// ════════════════════════════════════════════════════════════
// Add item
$('#btnAddItem').on('click', function () {
    items.push({ id:'', productId:'', description:'', quantity:1, unitPrice:0 });
    renderItems();
    // Focus last description input
    setTimeout(() => $('#itemsBody tr:last .item-desc').focus(), 50);
});

// Live edit on item rows (delegated)
$(document).on('input change', '.item-desc', function () {
    const idx = $(this).closest('tr').data('idx');
    items[idx].description = $(this).val();
});
$(document).on('input change', '.item-qty', function () {
    const idx = $(this).closest('tr').data('idx');
    items[idx].quantity = +$(this).val() || 0;
    const amt = (items[idx].quantity * (+items[idx].unitPrice||0)).toFixed(2);
    $(this).closest('tr').find('.item-amount').text(amt);
    calcTotals();
});
$(document).on('input change', '.item-price', function () {
    const idx = $(this).closest('tr').data('idx');
    items[idx].unitPrice = +$(this).val() || 0;
    const amt = ((+items[idx].quantity||0) * items[idx].unitPrice).toFixed(2);
    $(this).closest('tr').find('.item-amount').text(amt);
    calcTotals();
});
$(document).on('click', '.remove-item', function (e) {
    e.stopPropagation();
    const idx = +$(this).data('idx');
    items.splice(idx, 1);
    renderItems();
});

//Currency
// ── Currency symbols lookup ───────────────────────────────────
const currencySymbols = {
    INR:'₹', USD:'$', EUR:'€', GBP:'£', AUD:'A$',
    CAD:'C$', SGD:'S$', AED:'AED', JPY:'¥', CNY:'¥'
};
const baseCurrency = '@(ViewBag.CompanyCurrency ?? "INR")'; // from ViewBag

// ── Auto-fill currency when client changes ────────────────────
// $('#clientId').on('change', function() {
//     const clientId = $(this).val();
//     if (!clientId) return;
//     $.get('/Client/GetCurrency', { clientId: clientId })
//      .done(function(res) {
//          if (res.success && res.data && res.data.currency) {
//              const cur = res.data.currency;
//              $('#invoiceCurrency').val(cur);
//              updateCurrencyUI(cur);
//          }
//      });
// });

$('#clientId').on('change', function () {
    const clientId = $(this).val();
    if (!clientId) return;

    // Step 1: Get client currency
    $.get('/Client/GetCurrency', { clientId: clientId })
    .done(function (res) {

        if (res.success && res.data && res.data.currency) {

            const currency = res.data.currency;

            // Set currency dropdown
            $('#invoiceCurrency').val(currency);
            updateCurrencyUI(currency);

            // Step 2: If NOT base currency → call API
            if (currency !== baseCurrency) {

                $('#exchangeRate').val('Loading...');

                $.get('/Invoice/GetExchangeRate', {
                    from: currency,
                    to: baseCurrency
                })
                .done(function (rateRes) {

                    if (rateRes.success) {
                        $('#exchangeRate').val(rateRes.rate);
                    } else {
                        $('#exchangeRate').val(1);
                    }

                    updateConvertedAmount();
                })
                .fail(function () {
                    $('#exchangeRate').val(1);
                });
            }
            else {
                // Same currency
                $('#exchangeRate').val(1);
                updateConvertedAmount();
            }
        }
    });
});


// ── Update UI when currency dropdown changes ──────────────────
$('#invoiceCurrency').on('change', function() {
    updateCurrencyUI($(this).val());
});

function updateCurrencyUI(cur) {
    const sym    = currencySymbols[cur] || cur;
    const isBase = cur === baseCurrency;

    // Update labels
    $('#invoiceCurrencyLabel').text(cur);
    $('#baseCurrencyLabel').text(baseCurrency);
    // $('#perLabel').text('per 1 ' + cur + ' =');

    if (isBase) {
        $('#exchangeRate').val('1');
        $('#exchangeRateHint').text('Same currency — no conversion needed.');
        $('#exchangeRateSection').css('opacity','0.5');
        $('#convertedAmountSection').hide();
    } else {
        $('#exchangeRateHint').text(
            'Enter how many ' + baseCurrency + ' = 1 ' + cur +
            '. E.g. 1 USD = 83.50 INR → type 83.50'
        );
        $('#exchangeRateSection').css('opacity','1');
        $('#convertedAmountSection').show();
    }

    calcTotals(); // ← calls the real calcTotals which now includes updateConvertedAmount
}
// ── Recalculate converted amount when rate changes ──────────
$('#exchangeRate').on('input', function() {
    updateConvertedAmount();
});

// Patch calcTotals to show converted amount
// const _origCalcTotals = calcTotals; // keep reference
// function calcTotals() {
//     _origCalcTotals();  // call original
//     updateConvertedAmount();
// }

// ── Update the "Converted to INR" green box ─────────────────
// Called from inside calcTotals() (see patch below)
function updateConvertedAmount() {
    const total   = parseFloat($('#displayTotal').text().replace(/,/g,'')) || 0;
    const rate    = parseFloat($('#exchangeRate').val()) || 1;
    const cur     = $('#invoiceCurrency').val() || baseCurrency;
    const baseSym = currencySymbols[baseCurrency] || baseCurrency;
    const converted = (total * rate).toFixed(2);
    const formatted = parseFloat(converted).toLocaleString('en-IN', { minimumFractionDigits: 2 });
    $('#convertedAmountDisplay').text(baseSym + formatted);
}

function updateTotalSymbol(sym) {
    // Update the ₹ symbol shown next to the total in the summary
    // The totals section uses a currency symbol prefix — update it
    const el = document.getElementById('currencySymbol');
    if (el) el.textContent = sym;
}

// ── On edit: restore existing currency ──────────────────────
