@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Reset Password";
    var token = ViewBag.Token as string ?? "";
    ViewBag.TopHint = "Need help?";
    ViewBag.TopHintLink = "/Account/Login";
    ViewBag.TopHintText = "Back to sign in";
}

<div class="glass-card" style="max-width:440px;">
    <div class="text-center">
        <div class="icon-orb"><i class="bi bi-shield-lock"></i></div>
    </div>
    <h2 class="auth-heading text-center">Set a new password</h2>
    <p class="auth-subtle text-center">Choose a strong, unique password you haven&rsquo;t used elsewhere.</p>

    <form id="resetForm" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" id="token" value="@token"/>

        <div class="field">
            <label class="field__label">New password</label>
            <div class="field__control">
                <span class="field__icon"><i class="bi bi-lock"></i></span>
                <input type="password" id="newPassword" class="field__input" placeholder="Min. 8 characters" autocomplete="new-password"/>
                <button type="button" class="field__trail" id="toggleNew" tabindex="-1" aria-label="Show password"><i class="bi bi-eye" id="iconNew"></i></button>
            </div>

            <div class="strength"><div class="strength__fill" id="strengthBar"></div></div>
            <div class="strength__label" id="strengthHint">&nbsp;</div>

            <div class="req-pills">
                <span class="req-pill" id="req-len">8+ characters</span>
                <span class="req-pill" id="req-upper">Uppercase</span>
                <span class="req-pill" id="req-num">Number</span>
                <span class="req-pill" id="req-special">Special</span>
            </div>
            <span class="field__error" id="newPassError"></span>
        </div>

        <div class="field">
            <label class="field__label">Confirm password</label>
            <div class="field__control">
                <span class="field__icon"><i class="bi bi-lock-fill"></i></span>
                <input type="password" id="confirmPassword" class="field__input" placeholder="Repeat new password" autocomplete="new-password"/>
                <button type="button" class="field__trail" id="toggleConfirm" tabindex="-1" aria-label="Show password"><i class="bi bi-eye" id="iconConfirm"></i></button>
            </div>
            <span class="field__error" id="confirmError"></span>
        </div>

        <button type="submit" class="btn-aurora" id="submitBtn">
            <span id="btnText"><i class="bi bi-check2-circle me-1"></i>Update password</span>
            <span id="btnSpinner" class="d-none">
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Updating&hellip;
            </span>
        </button>
    </form>

    <div class="text-center" style="margin-top:1.25rem;">
        <a href="/Account/Login" class="link-violet"><i class="bi bi-arrow-left me-1"></i>Back to sign in</a>
    </div>
</div>

@section Scripts {
<script>
$(function(){
    function togglePass(inputSel,iconSel){
        var $f=$(inputSel),$i=$(iconSel);
        var isText=$f.attr('type')==='text';
        $f.attr('type',isText?'password':'text');
        $i.toggleClass('bi-eye',isText).toggleClass('bi-eye-slash',!isText);
    }
    $('#toggleNew').on('click',function(){togglePass('#newPassword','#iconNew')});
    $('#toggleConfirm').on('click',function(){togglePass('#confirmPassword','#iconConfirm')});

    function resetBtn(){$('#submitBtn').prop('disabled',false);$('#btnText').removeClass('d-none');$('#btnSpinner').addClass('d-none')}

    $('#newPassword').on('input',function(){
        var v=$(this).val();
        var checks={len:v.length>=8,upper:/[A-Z]/.test(v),num:/[0-9]/.test(v),special:/[^a-zA-Z0-9]/.test(v)};
        var score=0;$.each(checks,function(_,ok){if(ok)score++});
        $('#req-len').toggleClass('is-met',checks.len);
        $('#req-upper').toggleClass('is-met',checks.upper);
        $('#req-num').toggleClass('is-met',checks.num);
        $('#req-special').toggleClass('is-met',checks.special);

        var $bar=$('#strengthBar'),$hint=$('#strengthHint');
        if(!v.length){$bar.attr('data-level',null).css('width','0');$hint.text('').css('color','');return}
        $bar.attr('data-level',score);
        if(score<=1){$hint.text('Weak').css('color','#FCA5A5')}
        else if(score===2){$hint.text('Fair').css('color','#FBBF24')}
        else if(score===3){$hint.text('Good').css('color','#FBBF24')}
        else{$hint.text('Strong').css('color','#6EE7B7')}
    });

    $('#resetForm').on('submit',function(e){
        e.preventDefault();
        var np=$('#newPassword').val(),cp=$('#confirmPassword').val(),tk=$('#token').val();
        $('#newPassError,#confirmError').text('');var valid=true;
        if(!np||np.length<8){$('#newPassError').text('Min. 8 characters.');valid=false}
        else if(!/[A-Z]/.test(np)){$('#newPassError').text('Add an uppercase letter.');valid=false}
        else if(!/[0-9]/.test(np)){$('#newPassError').text('Add a number.');valid=false}
        else if(!/[^a-zA-Z0-9]/.test(np)){$('#newPassError').text('Add a special character.');valid=false}
        if(np!==cp){$('#confirmError').text('Passwords do not match.');valid=false}
        if(!valid)return;

        $('#submitBtn').prop('disabled',true);$('#btnText').addClass('d-none');$('#btnSpinner').removeClass('d-none');
        $.ajax({
            url:'/Account/ResetPassword',type:'POST',contentType:'application/json',
            data:JSON.stringify({token:tk,newPassword:np,confirmPassword:cp}),
            headers:{'RequestVerificationToken':$('input[name="__RequestVerificationToken"]').val()},
            success:function(r){
                if(r.success){
                    Swal.fire({
                        icon:'success',title:'Password updated',text:'Sign in with your new password.',
                        confirmButtonText:'Sign in',allowOutsideClick:false,
                        customClass:{popup:'swal-aurora'}
                    }).then(function(){window.location.href='/Account/Login'});
                }else{
                    Swal.fire({icon:'error',title:'Could not reset',text:r.message||'Reset failed.',customClass:{popup:'swal-aurora'}});
                    resetBtn();
                }
            },
            error:function(){
                Swal.fire({icon:'error',title:'Server error',text:'Please try again in a moment.',customClass:{popup:'swal-aurora'}});
                resetBtn();
            }
        });
    });

    $('#newPassword').trigger('focus');
});
</script>
}
