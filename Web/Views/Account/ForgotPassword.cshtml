@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Forgot Password";
    ViewBag.TopHint = "Remembered it?";
    ViewBag.TopHintLink = "/Account/Login";
    ViewBag.TopHintText = "Back to sign in";
}

<div class="glass-card" style="max-width:420px;">
    <div id="formState">
        <div class="text-center">
            <div class="icon-orb icon-orb--gold"><i class="bi bi-key"></i></div>
        </div>
        <h2 class="auth-heading text-center">Forgot your password?</h2>
        <p class="auth-subtle text-center">No worries — enter the email tied to your account and we&rsquo;ll send a secure reset link.</p>

        <form id="forgotForm" novalidate>
            @Html.AntiForgeryToken()

            <div class="field">
                <label for="email" class="field__label">Email address</label>
                <div class="field__control">
                    <span class="field__icon"><i class="bi bi-envelope"></i></span>
                    <input type="email" id="email" class="field__input" placeholder="you@company.com" autocomplete="email" required/>
                </div>
                <span class="field__error" id="emailError"></span>
            </div>

            <button type="submit" class="btn-aurora" id="submitBtn">
                <span id="btnText"><i class="bi bi-send me-1"></i>Send reset link</span>
                <span id="btnSpinner" class="d-none">
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Sending&hellip;
                </span>
            </button>
        </form>

        <div class="text-center" style="margin-top:1.25rem;">
            <a href="/Account/Login" class="link-violet"><i class="bi bi-arrow-left me-1"></i>Back to sign in</a>
        </div>
    </div>

    <div class="success-state" id="successState">
        <div class="success-orb"><i class="bi bi-envelope-check"></i></div>
        <h3 class="auth-heading" style="font-size:1.4rem;">Check your inbox</h3>
        <p class="auth-subtle">If that email is registered, a reset link is on its way. It expires in <strong style="color:var(--accent-gold);">24 hours</strong>.</p>
        <p style="color:var(--text-low);font-size:.82rem;margin-bottom:1.25rem;">
            Didn&rsquo;t get it? <a href="#" id="resendLink" class="link-gold">Try again</a>
        </p>
        <a href="/Account/Login" class="btn-ghost" style="display:inline-flex;">
            <i class="bi bi-arrow-left"></i> Back to sign in
        </a>
    </div>
</div>

@section Scripts {
<script>
$(function(){
    var $form=$('#forgotForm'),$btn=$('#submitBtn'),$txt=$('#btnText'),$spin=$('#btnSpinner');
    function resetBtn(){$btn.prop('disabled',false);$txt.removeClass('d-none');$spin.addClass('d-none')}

    $form.on('submit',function(e){
        e.preventDefault();
        var email=$('#email').val().trim();
        $('#emailError').text('');
        $('#email').closest('.field__control').css('border-color','');
        if(!email||!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)){
            $('#email').closest('.field__control').css('border-color','rgba(248,113,113,.55)');
            $('#emailError').text('Please enter a valid email address.');return;
        }
        $btn.prop('disabled',true);$txt.addClass('d-none');$spin.removeClass('d-none');
        $.ajax({
            url:'/Account/ForgotPassword',type:'POST',contentType:'application/json',
            data:JSON.stringify({email:email}),
            headers:{'RequestVerificationToken':$('input[name="__RequestVerificationToken"]').val()},
            complete:function(){
                $('#formState').fadeOut(200,function(){
                    $('#successState').addClass('is-shown');
                });
                resetBtn();
            }
        });
    });

    $('#resendLink').on('click',function(e){
        e.preventDefault();
        $('#successState').removeClass('is-shown');
        $('#formState').fadeIn(220);
        $('#email').trigger('focus');
    });

    $('#email').on('input',function(){
        $(this).closest('.field__control').css('border-color','');
        $('#emailError').text('');
    });
    $('#email').trigger('focus');
});
</script>
}
