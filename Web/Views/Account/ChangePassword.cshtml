@{
    Layout = "_Layout";
    ViewData["Title"] = "Change Password";
    ViewBag.ActiveMenu = "settings";
}

@section Styles {
<style>
    /* ── Aurora password card (scoped) ── */
    .ap-card{
        position:relative;
        background:linear-gradient(160deg,#11132A 0%,#1A1B3E 100%);
        border:1px solid rgba(139,92,246,.22);
        border-radius:20px;
        padding:2rem 2rem 2.25rem;
        color:#F8FAFC;
        box-shadow:0 18px 50px -18px rgba(99,102,241,.45),0 0 0 1px rgba(255,255,255,.04) inset;
        overflow:hidden;
        animation:ap-rise .7s cubic-bezier(.22,1,.36,1) both;
    }
    .ap-card::before{
        content:'';position:absolute;top:-40%;right:-25%;
        width:60%;aspect-ratio:1;border-radius:50%;
        background:radial-gradient(circle,rgba(139,92,246,.35),transparent 60%);
        filter:blur(48px);pointer-events:none;
    }
    .ap-card::after{
        content:'';position:absolute;bottom:-40%;left:-25%;
        width:55%;aspect-ratio:1;border-radius:50%;
        background:radial-gradient(circle,rgba(34,211,238,.22),transparent 60%);
        filter:blur(48px);pointer-events:none;
    }
    .ap-card > *{position:relative;z-index:1}
    @@keyframes ap-rise{0%{opacity:0;transform:translateY(20px) scale(.985)}100%{opacity:1;transform:translateY(0) scale(1)}}

    .ap-eyebrow{
        display:inline-block;color:#F5C56E;font-size:.7rem;font-weight:700;
        letter-spacing:.18em;text-transform:uppercase;margin-bottom:.6rem;
    }
    .ap-title{
        font-family:'Plus Jakarta Sans',Inter,sans-serif;
        font-size:1.5rem;font-weight:800;letter-spacing:-.025em;color:#F8FAFC;margin:0 0 .35rem;
    }
    .ap-sub{color:rgba(248,250,252,.72);font-size:.88rem;margin-bottom:1.5rem}

    .ap-orb{
        width:60px;height:60px;border-radius:16px;
        display:inline-flex;align-items:center;justify-content:center;
        background:linear-gradient(135deg,rgba(139,92,246,.28),rgba(99,102,241,.18));
        border:1px solid rgba(139,92,246,.32);
        color:#DDD6FE;font-size:1.5rem;
        box-shadow:0 10px 26px -10px rgba(139,92,246,.55);
        margin-bottom:1rem;
        animation:ap-bob 5.5s ease-in-out infinite;
    }
    @@keyframes ap-bob{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}

    .ap-field{margin-bottom:1.05rem}
    .ap-label{
        display:block;font-size:.78rem;font-weight:600;
        color:rgba(248,250,252,.72);margin-bottom:.45rem;
    }
    .ap-control{
        position:relative;display:flex;align-items:stretch;
        background:rgba(255,255,255,.04);
        border:1px solid rgba(255,255,255,.10);
        border-radius:12px;
        transition:border-color .22s ease,box-shadow .22s ease,background .22s ease;
    }
    .ap-control:focus-within{
        border-color:rgba(139,92,246,.6);
        box-shadow:0 0 0 4px rgba(139,92,246,.28);
        background:rgba(255,255,255,.07);
    }
    .ap-icon{
        display:inline-flex;align-items:center;justify-content:center;
        padding:0 .8rem 0 .9rem;color:rgba(248,250,252,.52);font-size:1rem;
        transition:color .22s ease;
    }
    .ap-control:focus-within .ap-icon{color:#8B5CF6}
    .ap-input{
        flex:1;background:transparent;border:0;outline:0;
        padding:.78rem .25rem;color:#F8FAFC;font-size:.92rem;font-family:inherit;
        caret-color:#8B5CF6;
    }
    .ap-input::placeholder{color:rgba(248,250,252,.45)}
    .ap-input:-webkit-autofill,.ap-input:-webkit-autofill:hover,.ap-input:-webkit-autofill:focus{
        -webkit-text-fill-color:#F8FAFC;-webkit-box-shadow:0 0 0 1000px transparent inset;
        transition:background-color 5000s ease-in-out 0s;
    }
    .ap-trail{
        background:transparent;border:0;color:rgba(248,250,252,.52);
        padding:0 .9rem;cursor:pointer;transition:color .18s ease;
    }
    .ap-trail:hover{color:#F8FAFC}
    .ap-err{display:block;font-size:.74rem;color:#FCA5A5;margin-top:.4rem;min-height:.9rem}

    .ap-strength{margin-top:.55rem;height:5px;border-radius:99px;background:rgba(255,255,255,.08);overflow:hidden}
    .ap-strength__fill{
        height:100%;width:0;border-radius:99px;
        background:linear-gradient(90deg,#EF4444,#F59E0B);
        transition:width .32s ease,background .32s ease;
    }
    .ap-strength__fill[data-level="1"]{width:25%;background:linear-gradient(90deg,#EF4444,#F87171)}
    .ap-strength__fill[data-level="2"]{width:50%;background:linear-gradient(90deg,#EF4444,#F59E0B)}
    .ap-strength__fill[data-level="3"]{width:75%;background:linear-gradient(90deg,#F59E0B,#FBBF24)}
    .ap-strength__fill[data-level="4"]{width:100%;background:linear-gradient(90deg,#10B981,#34D399)}

    .ap-pills{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.75rem}
    .ap-pill{
        display:inline-flex;align-items:center;gap:.32rem;
        padding:.3rem .65rem;font-size:.72rem;font-weight:500;
        background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);
        border-radius:99px;color:rgba(248,250,252,.52);
        transition:all .25s ease;
    }
    .ap-pill::before{content:'';width:5px;height:5px;border-radius:50%;background:rgba(248,250,252,.52);transition:all .25s ease}
    .ap-pill.is-met{background:rgba(16,185,129,.14);border-color:rgba(52,211,153,.35);color:#6EE7B7}
    .ap-pill.is-met::before{background:#34D399;box-shadow:0 0 0 3px rgba(52,211,153,.2)}

    .ap-btn{
        position:relative;width:100%;
        display:inline-flex;align-items:center;justify-content:center;gap:.5rem;
        padding:.82rem 1rem;
        font-family:'Plus Jakarta Sans',Inter,sans-serif;
        font-weight:700;font-size:.92rem;color:#fff;
        background:linear-gradient(135deg,#8B5CF6 0%,#6366F1 100%);
        border:0;border-radius:13px;cursor:pointer;overflow:hidden;
        box-shadow:0 10px 30px -8px rgba(139,92,246,.55);
        transition:transform .18s ease,box-shadow .25s ease,background .35s ease;
    }
    .ap-btn::after{
        content:'';position:absolute;top:0;bottom:0;left:-40%;width:35%;
        background:linear-gradient(110deg,transparent,rgba(255,255,255,.25),transparent);
        transform:skewX(-18deg);pointer-events:none;transition:left .9s ease;
    }
    .ap-btn:hover:not(:disabled){background:linear-gradient(135deg,#A78BFA 0%,#818CF8 100%);transform:translateY(-1px);box-shadow:0 14px 36px -8px rgba(139,92,246,.7);color:#fff}
    .ap-btn:hover:not(:disabled)::after{left:120%}
    .ap-btn:active:not(:disabled){transform:translateY(0) scale(.98)}
    .ap-btn:disabled{opacity:.65;cursor:not-allowed}

    .ap-btn-ghost{
        display:inline-flex;align-items:center;justify-content:center;gap:.5rem;
        padding:.82rem 1rem;font-weight:600;font-size:.9rem;
        color:rgba(248,250,252,.72);
        background:rgba(255,255,255,.04);
        border:1px solid rgba(255,255,255,.12);
        border-radius:13px;text-decoration:none;
        transition:all .22s ease;width:100%;
    }
    .ap-btn-ghost:hover{color:#F8FAFC;background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.2)}

    [data-theme="dark"] .ap-card{box-shadow:0 20px 60px -18px rgba(0,0,0,.55),0 0 0 1px rgba(255,255,255,.04) inset}
</style>
}

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-1 fw-bold">Change Password</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Change Password</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="ap-card">
            <div class="text-center">
                <div class="ap-orb"><i class="bi bi-shield-lock"></i></div>
                <span class="ap-eyebrow">Account Security</span>
                <h2 class="ap-title">Update your password</h2>
                <p class="ap-sub">Choose a strong password you haven&rsquo;t used before.</p>
            </div>

            <form id="changePasswordForm" novalidate>
                @Html.AntiForgeryToken()

                <div class="ap-field">
                    <label class="ap-label">Current password</label>
                    <div class="ap-control">
                        <span class="ap-icon"><i class="bi bi-lock"></i></span>
                        <input type="password" class="ap-input" id="currentPassword" placeholder="Your current password" autocomplete="current-password"/>
                        <button type="button" class="ap-trail" onclick="togglePass('currentPassword','iconCurrent')" tabindex="-1"><i class="bi bi-eye" id="iconCurrent"></i></button>
                    </div>
                    <span class="ap-err" id="currentError"></span>
                </div>

                <div class="ap-field">
                    <label class="ap-label">New password</label>
                    <div class="ap-control">
                        <span class="ap-icon"><i class="bi bi-lock-fill"></i></span>
                        <input type="password" class="ap-input" id="newPassword" placeholder="Min. 8 characters" autocomplete="new-password"/>
                        <button type="button" class="ap-trail" onclick="togglePass('newPassword','iconNew')" tabindex="-1"><i class="bi bi-eye" id="iconNew"></i></button>
                    </div>
                    <div class="ap-strength"><div class="ap-strength__fill" id="strengthBar"></div></div>
                    <div class="ap-pills">
                        <span class="ap-pill" id="req-len">8+ chars</span>
                        <span class="ap-pill" id="req-upper">Uppercase</span>
                        <span class="ap-pill" id="req-num">Number</span>
                        <span class="ap-pill" id="req-special">Special</span>
                    </div>
                    <span class="ap-err" id="newError"></span>
                </div>

                <div class="ap-field" style="margin-bottom:1.5rem;">
                    <label class="ap-label">Confirm new password</label>
                    <div class="ap-control">
                        <span class="ap-icon"><i class="bi bi-lock-fill"></i></span>
                        <input type="password" class="ap-input" id="confirmPassword" placeholder="Repeat new password" autocomplete="new-password"/>
                        <button type="button" class="ap-trail" onclick="togglePass('confirmPassword','iconConfirm')" tabindex="-1"><i class="bi bi-eye" id="iconConfirm"></i></button>
                    </div>
                    <span class="ap-err" id="confirmError"></span>
                </div>

                <div class="d-flex flex-column gap-2">
                    <button type="submit" class="ap-btn" id="submitBtn">
                        <span id="btnText"><i class="bi bi-check2-circle me-1"></i>Update password</span>
                        <span id="btnSpinner" class="d-none">
                            <span class="spinner-border spinner-border-sm me-2"></span>Updating&hellip;
                        </span>
                    </button>
                    <a href="/Dashboard" class="ap-btn-ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePass(inputId,iconId){
    var inp=document.getElementById(inputId),icon=document.getElementById(iconId);
    var show=inp.type==='password';
    inp.type=show?'text':'password';
    icon.className=show?'bi bi-eye-slash':'bi bi-eye';
}

$(function(){
    $('#newPassword').on('input',function(){
        var v=$(this).val();
        var checks={len:v.length>=8,upper:/[A-Z]/.test(v),num:/[0-9]/.test(v),special:/[^a-zA-Z0-9]/.test(v)};
        var score=Object.values(checks).filter(Boolean).length;
        $('#req-len').toggleClass('is-met',checks.len);
        $('#req-upper').toggleClass('is-met',checks.upper);
        $('#req-num').toggleClass('is-met',checks.num);
        $('#req-special').toggleClass('is-met',checks.special);
        var $bar=$('#strengthBar');
        if(!v.length){$bar.attr('data-level',null).css('width','0')}
        else{$bar.attr('data-level',score)}
    });

    $('#changePasswordForm').on('submit',function(e){
        e.preventDefault();
        $('#currentError, #newError, #confirmError').text('');
        var curr=$('#currentPassword').val(),nw=$('#newPassword').val(),conf=$('#confirmPassword').val();
        var valid=true;
        if(!curr){$('#currentError').text('Current password is required.');valid=false}
        if(!nw||nw.length<8){$('#newError').text('Min. 8 characters required.');valid=false}
        else if(!/[A-Z]/.test(nw)){$('#newError').text('Must contain an uppercase letter.');valid=false}
        else if(!/[0-9]/.test(nw)){$('#newError').text('Must contain a number.');valid=false}
        else if(!/[^a-zA-Z0-9]/.test(nw)){$('#newError').text('Must contain a special character.');valid=false}
        if(nw!==conf){$('#confirmError').text('Passwords do not match.');valid=false}
        if(!valid)return;

        $('#submitBtn').prop('disabled',true);
        $('#btnText').addClass('d-none');
        $('#btnSpinner').removeClass('d-none');

        $.ajax({
            url:'/Account/ChangePassword',type:'POST',contentType:'application/json',
            data:JSON.stringify({currentPassword:curr,newPassword:nw,confirmPassword:conf}),
            headers:{'RequestVerificationToken':$('input[name="__RequestVerificationToken"]').val()},
            success:function(res){
                if(res.success){
                    Swal.fire({
                        icon:'success',title:'Password updated!',
                        text:'Please sign in with your new password.',
                        confirmButtonColor:'#8B5CF6',confirmButtonText:'Sign in',allowOutsideClick:false
                    }).then(function(){window.location.href='/Account/Login'});
                }else{
                    Swal.fire({icon:'error',title:'Error',text:res.message,confirmButtonColor:'#8B5CF6'});
                    resetBtn();
                }
            },
            error:function(){
                Swal.fire({icon:'error',title:'Error',text:'Server error. Please try again.',confirmButtonColor:'#8B5CF6'});
                resetBtn();
            }
        });

        function resetBtn(){
            $('#submitBtn').prop('disabled',false);
            $('#btnText').removeClass('d-none');
            $('#btnSpinner').addClass('d-none');
        }
    });
});
</script>
}
