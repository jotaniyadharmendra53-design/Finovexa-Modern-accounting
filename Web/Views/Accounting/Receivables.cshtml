@* @{
    ViewData["Title"] = "Accounts Receivable";
    ViewBag.ActiveMenu = "accounting";
}

@section Styles {
<style>
#spinner { display:none; }
.aging-current { color:#16A34A; }
.aging-30 { color:#D97706; }
.aging-60 { color:#2563EB; }
.aging-over { color:#DC2626; font-weight:600; }
</style>
}

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h4 class="mb-1">Accounts Receivable</h4>
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Accounting">Accounting</a></li>
            <li class="breadcrumb-item active">Receivables</li>
        </ol></nav>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary" onclick="loadReport()">
            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        </button>
        <button class="btn btn-sm btn-outline-secondary" onclick="exportCsv()">
            <i class="bi bi-download me-1"></i>Export
        </button>
    </div>
</div>

<!-- Aging summary cards -->
<div class="row g-3 mb-4" id="agingCards" style="display:none!important">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">Current</div>
                <div class="fw-700 fs-5 aging-current" id="cTotal">₹0</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">1–30 days overdue</div>
                <div class="fw-700 fs-5 aging-30" id="c30">₹0</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">31–60 days overdue</div>
                <div class="fw-700 fs-5 aging-60" id="c60">₹0</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">60+ days overdue</div>
                <div class="fw-700 fs-5 aging-over" id="cOver">₹0</div>
            </div>
        </div>
    </div>
</div>

<div id="spinner" class="text-center py-5">
    <div class="spinner-border text-primary" style="width:2rem;height:2rem;"></div>
    <div class="text-muted small mt-2">Loading…</div>
</div>

<div id="reportContent" style="display:none">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent">
            <h6 class="fw-600 mb-0">Outstanding by Client</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Client</th>
                            <th class="text-end aging-current">Current</th>
                            <th class="text-end aging-30">1–30 days</th>
                            <th class="text-end aging-60">31–60 days</th>
                            <th class="text-end aging-over">60+ days</th>
                            <th class="text-end fw-600">Total</th>
                        </tr>
                    </thead>
                    <tbody id="tbody"></tbody>
                    <tfoot id="tfoot" class="table-light fw-600"></tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var reportData = [];
function fmt(n){ return '₹' + parseFloat(n||0).toLocaleString('en-IN',{minimumFractionDigits:2,maximumFractionDigits:2}); }

// function loadReport(){
//     document.getElementById('spinner').style.display = 'block';
//     document.getElementById('reportContent').style.display = 'none';

//     $.get('/Accounting/Receivables', function(res){
//         document.getElementById('spinner').style.display = 'none';
//         if(!res.success){ toastError(res.message||'Failed to load.'); return; }
//         reportData = res.data || [];
//         renderReport(reportData);
//         document.getElementById('reportContent').style.display = 'block';
//     }).fail(function(){
//         document.getElementById('spinner').style.display = 'none';
//         toastError('Failed to load receivables.');
//     });
// }

function loadReport(){
    document.getElementById('spinner').style.display = 'block';
    document.getElementById('reportContent').style.display = 'none';

    $.ajax({
        // url: '/Accounting/Receivables',
           url: '/Accounting/ReceivablesData',
        type: 'GET',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        success: function(res){
            document.getElementById('spinner').style.display = 'none';
            if(!res.success){ toastError(res.message||'Failed to load.'); return; }
            reportData = res.data || [];
            renderReport(reportData);
            document.getElementById('reportContent').style.display = 'block';
        },
        error: function(){
            document.getElementById('spinner').style.display = 'none';
            toastError('Failed to load receivables.');
        }
    });
}

function renderReport(rows){
    var tbody = '', tfoot = '';
    var totals = {current:0, d30:0, d60:0, over:0, total:0};

    if(!rows.length){
        tbody = '<tr><td colspan="6" class="text-center text-muted py-5">'
              + '<i class="bi bi-check-circle text-success fs-2 d-block mb-2"></i>'
              + 'All invoices are paid. No outstanding receivables.</td></tr>';
    } else {
        rows.forEach(function(r){
            totals.current += parseFloat(r.current||0);
            totals.d30     += parseFloat(r.days1_30||0);
            totals.d60     += parseFloat(r.days31_60||0);
            totals.over    += parseFloat(r.over60||0);
            totals.total   += parseFloat(r.total||0);

            tbody += '<tr>'
                + '<td class="fw-600">' + (r.name||'—') + '</td>'
                + '<td class="text-end aging-current">' + (parseFloat(r.current||0)>0?fmt(r.current):'—') + '</td>'
                + '<td class="text-end aging-30">' + (parseFloat(r.days1_30||0)>0?fmt(r.days1_30):'—') + '</td>'
                + '<td class="text-end aging-60">' + (parseFloat(r.days31_60||0)>0?fmt(r.days31_60):'—') + '</td>'
                + '<td class="text-end aging-over">' + (parseFloat(r.over60||0)>0?fmt(r.over60):'—') + '</td>'
                + '<td class="text-end fw-600 text-danger">' + fmt(r.total) + '</td>'
                + '</tr>';
        });

        tfoot = '<tr>'
            + '<td>Total</td>'
            + '<td class="text-end aging-current">' + fmt(totals.current) + '</td>'
            + '<td class="text-end aging-30">'  + fmt(totals.d30) + '</td>'
            + '<td class="text-end aging-60">'  + fmt(totals.d60) + '</td>'
            + '<td class="text-end aging-over">' + fmt(totals.over) + '</td>'
            + '<td class="text-end text-danger">' + fmt(totals.total) + '</td>'
            + '</tr>';

        // Update summary cards
        document.getElementById('cTotal').textContent = fmt(totals.current);
        document.getElementById('c30').textContent    = fmt(totals.d30);
        document.getElementById('c60').textContent    = fmt(totals.d60);
        document.getElementById('cOver').textContent  = fmt(totals.over);
        document.getElementById('agingCards').style.cssText = 'display:flex!important;flex-wrap:wrap;gap:12px;margin-bottom:16px;';
        // use standard Bootstrap row instead
        document.getElementById('agingCards').removeAttribute('style');
        document.getElementById('agingCards').style.display = '';
    }

    document.getElementById('tbody').innerHTML = tbody;
    document.getElementById('tfoot').innerHTML = tfoot;
}

function exportCsv(){
    if(!reportData.length){ toastError('No data to export.'); return; }
    var rows = [['Client','Current','1-30 days','31-60 days','60+ days','Total']];
    reportData.forEach(function(r){
        rows.push([r.name,r.current,r.days1_30,r.days31_60,r.over60,r.total]);
    });
    var csv = rows.map(function(r){ return r.map(function(c){ return '"'+(c||0)+'"'; }).join(','); }).join('\n');
    var blob = new Blob([csv],{type:'text/csv'});
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'Receivables_Aging.csv';
    a.click();
}

$(function(){ loadReport(); });
</script>
} *@


