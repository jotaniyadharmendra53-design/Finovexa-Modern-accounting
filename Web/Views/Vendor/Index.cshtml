@model IEnumerable<VendorDto>
@{
    var perms = ViewBag.Permissions as HashSet<string> ?? new HashSet<string>();
    bool isSA = (bool)(ViewBag.IsSuperAdmin ?? false);
    bool Can(string c) => isSA || perms.Contains(c); ViewData["Title"] = "Vendors"; ViewBag.ActiveMenu = "vendors";
    int currentPage = (int)(ViewBag.Page ?? 1);
    int pageSize = (int)(ViewBag.PageSize ?? 20);
    int totalCount = (int)(ViewBag.TotalCount ?? 0);
    int totalPages = (int)(ViewBag.TotalPages ?? 1);
    var activeSearch = ViewBag.Search ?? "";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-1">Vendors</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Vendors</li>
            </ol>
        </nav>
    </div>
    @if (Can("vendors.create"))
    {
        <button class="btn btn-primary" onclick="openModal()">
            <i class="bi bi-plus-lg me-1"></i> Add Vendor
        </button>
    }
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-3">
        <div class="input-group input-group-sm" style="max-width:340px">
            <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" id="searchInput" class="form-control border-start-0" placeholder="Search vendors…" value="@activeSearch" oninput="filterTable()">
        </div>
    </div>
</div>

<div id="vendorsListCard" class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Vendor</th>
                        <th>Contact</th>
                        <th>Phone / Email</th>
                        <th>Payment Terms</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="tbody">
                    @foreach (var v in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-600">@v.Name</div>
                                @if (!string.IsNullOrEmpty(v.TaxNumber))
                                {
                                    <div class="text-muted small">Tax: @v.TaxNumber</div>
                                }
                            </td>
                            <td class="text-muted small">@(v.ContactPerson ?? "—")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(v.Phone))
                                {
                                    <div class="small">@v.Phone</div>
                                }
                                @if (!string.IsNullOrEmpty(v.Email))
                                {
                                    <div class="text-muted small">@v.Email</div>
                                }
                            </td>
                            <td><span class="badge bg-light text-dark border">@(v.PaymentTerms ?? "—")</span></td>
                            <td>
                                @if (v.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {

                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (Can("vendors.edit"))
                                {
                                    <button class="btn btn-sm btn-outline-primary me-1" onclick="editVendor('@v.Id')">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                }
                                @if (Can("vendors.delete"))
                                {
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteVendor('@v.Id','@v.Name')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="bi bi-truck fs-2 d-block mb-2 opacity-25"></i>
                                No vendors yet. Add your first vendor.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Pagination *@
    @if (totalPages > 0)
    {
        <div class="card-footer bg-transparent border-top d-flex align-items-center justify-content-between px-3 py-2">
            <span class="text-muted small">
                Showing @((currentPage - 1) * pageSize + 1)–@(Math.Min(currentPage * pageSize, totalCount)) of @totalCount vendors
            </span>
            <nav>
                <ul class="pagination pagination-sm mb-0 gap-1">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link rounded" href="@BuildUrl(currentPage - 1, activeSearch, pageSize)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @{
                        int start = Math.Max(1, currentPage - 2);
                        int end   = Math.Min(totalPages, start + 4);
                        start     = Math.Max(1, end - 4);
                    }
                    @if (start > 1)
                    {
                        <li class="page-item">
                            <a class="page-link rounded" href="@BuildUrl(1, activeSearch, pageSize)">1</a>
                        </li>
                        @if (start > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }
                    @for (int pg = start; pg <= end; pg++)
                    {
                        <li class="page-item @(pg == currentPage ? "active" : "")">
                            <a class="page-link rounded" href="@BuildUrl(pg, activeSearch, pageSize)">@pg</a>
                        </li>
                    }
                    @if (end < totalPages)
                    {
                        @if (end < totalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link rounded" href="@BuildUrl(totalPages, activeSearch, pageSize)">@totalPages</a>
                        </li>
                    }
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link rounded" href="@BuildUrl(currentPage + 1, activeSearch, pageSize)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted small">Per page:</span>
                <select class="form-select form-select-sm" style="width:70px" id="pageSizeSelect">
                    @foreach (var ps in new[] { 10, 20, 50, 100 })
                    {
                        if (ps == pageSize)
                        {
                            <option value="@ps" selected="selected">@ps</option>
                        }
                        else
                        {
                            <option value="@ps">@ps</option>
                        }
                    }
                </select>
            </div>
        </div>
    }

@functions {
    string BuildUrl(int page, string search, int pageSize)
    {
        var q = new System.Collections.Generic.List<string>();
        if (!string.IsNullOrEmpty(search)) q.Add($"search={Uri.EscapeDataString(search)}");
        q.Add($"page={page}");
        q.Add($"pageSize={pageSize}");
        return "/Vendor?" + string.Join("&", q);
    }
}

</div>

<!-- Modal -->
<div class="modal fade" id="vendorModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Vendor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="vId">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Vendor Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="vName" placeholder="Company or person name">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Contact Person</label>
                        <input type="text" class="form-control" id="vContact" placeholder="Primary contact name">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" id="vEmail" placeholder="vendor@example.com">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone</label>
                        <input type="text" class="form-control" id="vPhone" placeholder="+91 98765 43210">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">City</label>
                        <input type="text" class="form-control" id="vCity" placeholder="City">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Country</label>
                        <input type="text" class="form-control" id="vCountry" value="India">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Tax / GST Number <span class="text-danger">*</span> </label>
                        <input type="text" class="form-control" id="vTaxNo" placeholder="27AAAAA0000A1Z5">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Payment Terms</label>
                        <select class="form-select" id="vTerms">
                            <option value="">Select…</option>
                            <option>Immediate</option>
                            <option>Net 7</option>
                            <option>Net 15</option>
                            <option>Net 30</option>
                            <option>Net 60</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Address</label>
                        <textarea class="form-control" id="vAddress" rows="2" placeholder="Street address…"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Notes</label>
                        <textarea class="form-control" id="vNotes" rows="2" placeholder="Any notes…"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSave" onclick="saveVendor()">
                    <i class="bi bi-check-lg me-1"></i> Save Vendor
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var modal = new bootstrap.Modal(document.getElementById('vendorModal'));
        function openModal(){ clearForm(); document.getElementById('modalTitle').textContent='Add Vendor'; modal.show(); }

        function clearForm(){
            ['vId','vName','vContact','vEmail','vPhone','vCity','vTaxNo','vAddress','vNotes'].forEach(id=>document.getElementById(id).value='');
            document.getElementById('vCountry').value='India';
            document.getElementById('vTerms').value='';
        }

        function editVendor(id){
            $.get('/Vendor/GetById?id='+id, function(res){
                if(!res.success){ toastError(res.message); return; }
                var d=res.data;
                document.getElementById('vId').value=d.id;
                document.getElementById('vName').value=d.name||'';
                document.getElementById('vContact').value=d.contactPerson||'';
                document.getElementById('vEmail').value=d.email||'';
                document.getElementById('vPhone').value=d.phone||'';
                document.getElementById('vCity').value=d.city||'';
                document.getElementById('vCountry').value=d.country||'India';
                document.getElementById('vTaxNo').value=d.taxNumber||'';
                document.getElementById('vTerms').value=d.paymentTerms||'';
                document.getElementById('vAddress').value=d.address||'';
                document.getElementById('vNotes').value=d.notes||'';
                document.getElementById('modalTitle').textContent='Edit Vendor';
                modal.show();
            });
        }

        function saveVendor(){
            var name=document.getElementById('vName').value.trim();
            var taxNumber=document.getElementById('vTaxNo').value.trim();

            if(!name)
            {  
                toastError('Vendor name is required.'); 
                return; 
            }

            if(!taxNumber)
            {
                toastError('Vendor TaxNumber is required.');
                return;
            }

            var $btn=$('#btnSave').prop('disabled',true).html('<span class="spinner-border spinner-border-sm"></span>');
            var dto={
                id: document.getElementById('vId').value||null,
                name: name,
                contactPerson: document.getElementById('vContact').value.trim()||null,
                email: document.getElementById('vEmail').value.trim()||null,
                phone: document.getElementById('vPhone').value.trim()||null,
                city: document.getElementById('vCity').value.trim()||null,
                country: document.getElementById('vCountry').value.trim()||null,
                taxNumber: document.getElementById('vTaxNo').value.trim()||null,
                paymentTerms: document.getElementById('vTerms').value||null,
                address: document.getElementById('vAddress').value.trim()||null,
                notes: document.getElementById('vNotes').value.trim()||null
            };
            ajaxPost('/Vendor/Save',dto,$btn).done(function(res){
                $btn.prop('disabled',false).html('<i class="bi bi-check-lg me-1"></i> Save Vendor');
                if(res.success){ toastSuccess(res.message); modal.hide(); setTimeout(()=>location.reload(),700); }
                else toastError(res.message);
            });
        }

        function deleteVendor(id,name){
            confirmDelete({title:'Delete vendor?',text:'"'+name+'"'}).then(function(r){
                if(!r.isConfirmed) return;
                ajaxPost('/Vendor/Delete?id='+id,{}).done(function(res){
                    if(res.success){ toastSuccess(res.message); setTimeout(()=>location.reload(),700); }
                    else toastError(res.message);
                });
            });
        }

        function filterTable(){
            var q=document.getElementById('searchInput').value.toLowerCase();
            document.querySelectorAll('#tbody tr').forEach(tr=>tr.style.display=tr.textContent.toLowerCase().includes(q)?'':'none');
        }

        // AJAX pagination for vendors (no full reload)
        function loadVendorsFromUrl(url) {
            $.get(url).done(function (html) {
                var tmp = $('<div>').append($.parseHTML(html));
                var newCard = tmp.find('#vendorsListCard');
                if (newCard.length) {
                    $('#vendorsListCard').replaceWith(newCard);
                    setupVendorPaginationHandlers();
                    initVendorHandlers();
                } else {
                    window.location.href = url; // fallback
                }
            }).fail(function () { toastError('Failed to load vendors.'); });
        }

        function setupVendorPaginationHandlers() {
            $('#pageSizeSelect').off('change').on('change', function () {
                var ps = $(this).val();
                var s = encodeURIComponent($('#searchInput').val() || '');
                var url = '/Vendor?page=1&pageSize=' + ps + (s ? '&search=' + s : '');
                loadVendorsFromUrl(url);
            });

            $(document).off('click', '#vendorsListCard .pagination a').on('click', '#vendorsListCard .pagination a', function (e) {
                e.preventDefault();
                var href = $(this).attr('href');
                if (href) loadVendorsFromUrl(href);
            });
        }

        function initVendorHandlers() {
            // rebind local search filter
            $('#searchInput').off('input').on('input', filterTable);
        }

        // initialize handlers on page load
        setupVendorPaginationHandlers();
        initVendorHandlers();
    </script>
}
