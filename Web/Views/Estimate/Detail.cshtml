
@model EstimateDto
@{
    var perms = ViewBag.Permissions as HashSet<string> ?? new HashSet<string>();
    bool isSA = (bool)(ViewBag.IsSuperAdmin ?? false);
    bool Can(string c) => isSA || perms.Contains(c); ViewData["Title"] = Model.EstimateNumber; ViewBag.ActiveMenu = "estimates";
}

@{
    var badge = Model.Status switch
    {
        0 => "bg-secondary",
        1 => "bg-primary",
        2 => "bg-success",
        3 => "bg-danger",
        4 => "bg-info",
        _ => "bg-secondary"
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-1">@Model.EstimateNumber <span class="badge @badge ms-2">@Model.StatusName</span></h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/Estimate">Estimates</a></li>
                <li class="breadcrumb-item active">@Model.EstimateNumber</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (Model.Status == 0 && Can("estimates.edit"))
        {
            <a href="/Estimate/Edit/@Model.Id" class="btn btn-outline-primary">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
        }
        @if ((Model.Status == 0 || Model.Status == 1) && Can("estimates.send"))
        {
            <button class="btn btn-success" onclick="sendEst()">
                <i class="bi bi-send me-1"></i>Send to Client
            </button>
        }
        @if (Model.Status == 2 && Can("estimates.convert"))
        {
            <button class="btn btn-primary" onclick="convertEst()">
                <i class="bi bi-arrow-right-circle me-1"></i>Convert to Invoice
            </button>
        }
        @if (Model.ConvertedInvoiceId.HasValue)
        {
            <a href="/Invoice/Detail/@Model.ConvertedInvoiceId" class="btn btn-outline-info">
                <i class="bi bi-file-earmark-text me-1"></i>View Invoice
            </a>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <!-- Estimate document card -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <!-- Header -->
                <div class="d-flex justify-content-between mb-4">
                    <div>
                        <h5 class="fw-700 mb-0">ESTIMATE</h5>
                        <div class="text-muted">@Model.EstimateNumber</div>
                    </div>
                    <div class="text-end">
                        <div class="small text-muted">Issued: @Model.IssueDate.ToString("dd MMM yyyy")</div>
                        <div class="small @(Model.IsExpired ? "text-danger fw-600" : "text-muted")">
                            Expires: @Model.ExpiryDate.ToString("dd MMM yyyy")
                        </div>
                    </div>
                </div>

                <!-- Client -->
                <div class="row mb-4">
                    <div class="col-6">
                        <div class="text-muted small fw-600 text-uppercase mb-1" style="letter-spacing:.06em">Prepared For</div>
                        <div class="fw-600">@Model.ClientName</div>
                        @if (!string.IsNullOrEmpty(Model.ClientEmail))
                        {
                            <div class="text-muted small">@Model.ClientEmail</div>
                        }
                    </div>
                    <div class="col-6 text-end">
                        <div class="fs-3 fw-700 text-primary">₹@Model.Total.ToString("N2")</div>
                        <div class="text-muted small">Total value</div>
                    </div>
                </div>

                <!-- Line items -->
                <table class="table table-sm mb-3">
                    <thead class="table-light">
                        <tr>
                            <th>Description</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items.OrderBy(i => i.SortOrder))
                        {
                            <tr>
                                <td>@item.Description</td>
                                <td class="text-end">@item.Quantity</td>
                                <td class="text-end">₹@item.UnitPrice.ToString("N2")</td>
                                <td class="text-end fw-600">₹@item.Amount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <!-- Totals -->
                <div class="d-flex justify-content-end">
                    <table style="min-width:260px">
                        <tr><td class="text-muted pe-4">Subtotal</td><td class="text-end">₹@Model.SubTotal.ToString("N2")</td></tr>
                        @if (Model.TaxRate > 0)
                        {
                            <tr><td class="text-muted pe-4">Tax (@Model.TaxRate%)</td><td class="text-end">₹@Model.TaxAmount.ToString("N2")</td></tr>
                        }
                        @if (Model.Discount > 0)
                        {
                            <tr><td class="text-muted pe-4">Discount</td><td class="text-end text-success">-₹@Model.Discount.ToString("N2")</td></tr>
                        }
                        <tr style="border-top:2px solid #E5E7EB">
                            <td class="fw-700 pt-2 pe-4">Total</td>
                            <td class="fw-700 text-primary pt-2 text-end fs-5">₹@Model.Total.ToString("N2")</td>
                        </tr>
                    </table>
                </div>

                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <hr>
                    <div class="text-muted small"><strong>Notes:</strong> @Model.Notes</div>
                }
                @if (!string.IsNullOrEmpty(Model.Terms))
                {
                    <div class="text-muted small mt-1"><strong>Terms:</strong> @Model.Terms</div>
                }
            </div>
        </div>
    </div>

    <!-- Right: Status timeline -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-600 mb-3">Timeline</h6>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex gap-2 align-items-center">
                        <i class="bi bi-check-circle-fill text-success"></i>
                        <div>
                            <div class="small fw-600">Created</div>
                            <div class="text-muted small">@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</div>
                        </div>
                    </div>
                    @if (Model.SentAt.HasValue)
                    {
                        <div class="d-flex gap-2 align-items-center">
                            <i class="bi bi-send text-primary"></i>
                            <div>
                                <div class="small fw-600">Sent to client</div>
                                <div class="text-muted small">@Model.SentAt.Value.ToString("dd MMM yyyy, HH:mm")</div>
                            </div>
                        </div>
                    }
                    @if (Model.ConvertedInvoiceId.HasValue)
                    {
                        <div class="d-flex gap-2 align-items-center">
                            <i class="bi bi-arrow-right-circle-fill text-info"></i>
                            <div>
                                <div class="small fw-600">Converted to Invoice</div>
                                <div class="text-muted small"><a href="/Invoice/Detail/@Model.ConvertedInvoiceId">View invoice</a></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-600 mb-3">Details</h6>
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">Number</dt>
                    <dd class="col-7">@Model.EstimateNumber</dd>
                    <dt class="col-5 text-muted">Client</dt>
                    <dd class="col-7">@Model.ClientName</dd>
                    <dt class="col-5 text-muted">Issued</dt>
                    <dd class="col-7">@Model.IssueDate.ToString("dd MMM yyyy")</dd>
                    <dt class="col-5 text-muted">Expires</dt>
                    <dd class="col-7 @(Model.IsExpired ? "text-danger fw-600" : "")">@Model.ExpiryDate.ToString("dd MMM yyyy")</dd>
                    <dt class="col-5 text-muted">Status</dt>
                    <dd class="col-7"><span class="badge @badge">@Model.StatusName</span></dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function sendEst(){
            Swal.fire({icon:'question',title:'Send estimate?',
                html:'Send <b>@Model.EstimateNumber</b> to <b>@Model.ClientName</b>?',
                confirmButtonText:'Send',confirmButtonColor:'#2563EB',showCancelButton:true
            }).then(function(r){
                if(!r.isConfirmed) return;
                ajaxPost('/Estimate/Send?id=@Model.Id',{}).done(function(res){
                    if(res.success){ toastSuccess(res.message); setTimeout(()=>location.reload(),800); }
                    else toastError(res.message);
                });
            });
        }
        function convertEst(){
            Swal.fire({icon:'question',title:'Convert to invoice?',
                html:'Create a new invoice from this estimate?',
                confirmButtonText:'Convert',confirmButtonColor:'#0F6E56',showCancelButton:true
            }).then(function(r){
                if(!r.isConfirmed) return;
                ajaxPost('/Estimate/Convert?id=@Model.Id',{}).done(function(res){
                    if(res.success){ toastSuccess(res.message); setTimeout(function(){ window.location='/Invoice/Detail/'+res.data.invoiceId; },900); }
                    else toastError(res.message);
                });
            });
        }
    </script>
}
